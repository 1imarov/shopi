{{ 'section-product-grid.css' | asset_url | stylesheet_tag }}

<section class="product-grid">
  <div class="page-width">
    <div class="product-grid__header">
      {% if section.settings.heading != blank %}
        <h2 class="product-grid__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="product-grid__text rte">
          {{ section.settings.text }}
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="product-grid__grid">
        {% for block in section.blocks %}
          <div class="product-card" {{ block.shopify_attributes }}>
            <div class="product-card__image-wrapper">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                    class: 'product-card__image',
                    loading: 'lazy',
                    alt: block.settings.title
                }}
              {% else %}
                <div class="product-card__placeholder-image"></div>
              {% endif %}
            </div>

            <div class="product-card__info">
              {% if block.settings.title != blank %}
                <h3 class="product-card__title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.price != blank %}
                <div class="product-card__price">{{ block.settings.price }}</div>
              {% endif %}

              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="button product-card__button">
                  {{ block.settings.button_label }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Highlight selected items with editable product-style cards.</p>"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Essential hoodie"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$89.00"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product grid",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}